386  			bool all_fmus_support_get_state = false;
387  			dataWriter1.writeDataPoint(datawriter_configuration, jac_current_communication_point, optRealShare[0], optRealShare[1], prxRealShare[0]);
388  			bool any_discards = false;
389  			while( (jac_current_communication_point + jac_current_step_size) < jac_end_time )
390  			{
391  				bool tmp = simulationControl.stopRequested();
392  				if( tmp )
393  				{
394  						error "Simulation stopped by user";
395  				}
396  				@Transfer();
397  				optUintVref[0] = 0;
398  				optRealIo[0] = prxRealShare[0];
399  				status = opt.setReal(optUintVref, 1, optRealIo);
400  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
401  				{
402  						if( status == FMI_ERROR )
403  						{
404  								logger.log(4, "SetReal failed on '%s' with status: FMI_ERROR", opt);
405  						}
406  						if( status == FMI_FATAL )
407  						{
408  								logger.log(4, "SetReal failed on '%s' with status: FMI_FATAL", opt);
409  						}
410  						error "Failed to 'setReal' on 'opt'";
411  				}
412  				prxUintVref[0] = 0;
413  				prxUintVref[1] = 1;
414  				prxRealIo[0] = optRealShare[0];
415  				prxRealIo[1] = optRealShare[1];
416  				status = prx.setReal(prxUintVref, 2, prxRealIo);
417  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
418  				{
419  						if( status == FMI_ERROR )
420  						{
421  								logger.log(4, "SetReal failed on '%s' with status: FMI_ERROR", prx);
422  						}
423  						if( status == FMI_FATAL )
424  						{
425  								logger.log(4, "SetReal failed on '%s' with status: FMI_FATAL", prx);
426  						}
427  						error "Failed to 'setReal' on 'prx'";
428  				}
429  				any_discards = false;
430  				status = opt.doStep(jac_current_communication_point, jac_current_step_size, false);
431  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
432  				{
433  						if( status == FMI_ERROR )
434  						{
435  								logger.log(4, "DoStep failed on '%s' with status: FMI_ERROR", opt);
436  						}
437  						if( status == FMI_FATAL )
438  						{
439  								logger.log(4, "DoStep failed on '%s' with status: FMI_FATAL", opt);
440  						}
441  						error "Failed to 'doStep' on 'opt'";
442  				}
443  				if( status != FMI_OK )
444  				{
445  						if( status == FMI_DISCARD )
446  						{
447  								status = opt.getRealStatus(2, ref optCurrentTime);
448  								optCurrentTimeFullStep = false;
449  						}
450  				}
451  				else
452  				{
453  						optCurrentTime = jac_current_communication_point + jac_current_step_size;
454  						optCurrentTimeFullStep = true;
455  				}
456  				fmu_communicationpoints[0] = optCurrentTime;
457  				if( !optCurrentTimeFullStep )
458  				{
459  						logger.log(1, "## FMU: '%s' DISCARDED step at sim-time: %f for step-size: %f and proposed sim-time: %.15f", "opt", jac_current_communication_point, jac_current_step_size, optCurrentTime);
460  						any_discards = any_discards || !optCurrentTimeFullStep;
461  				}
462  				status = prx.doStep(jac_current_communication_point, jac_current_step_size, false);
463  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
464  				{
