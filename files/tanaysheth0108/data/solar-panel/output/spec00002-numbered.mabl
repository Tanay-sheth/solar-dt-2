466  						{
467  								logger.log(4, "DoStep failed on '%s' with status: FMI_ERROR", prx);
468  						}
469  						if( status == FMI_FATAL )
470  						{
471  								logger.log(4, "DoStep failed on '%s' with status: FMI_FATAL", prx);
472  						}
473  						error "Failed to 'doStep' on 'prx'";
474  				}
475  				if( status != FMI_OK )
476  				{
477  						if( status == FMI_DISCARD )
478  						{
479  								status = prx.getRealStatus(2, ref prxCurrentTime);
480  								prxCurrentTimeFullStep = false;
481  						}
482  				}
483  				else
484  				{
485  						prxCurrentTime = jac_current_communication_point + jac_current_step_size;
486  						prxCurrentTimeFullStep = true;
487  				}
488  				fmu_communicationpoints[1] = prxCurrentTime;
489  				if( !prxCurrentTimeFullStep )
490  				{
491  						logger.log(1, "## FMU: '%s' DISCARDED step at sim-time: %f for step-size: %f and proposed sim-time: %.15f", "prx", jac_current_communication_point, jac_current_step_size, prxCurrentTime);
492  						any_discards = any_discards || !prxCurrentTimeFullStep;
493  				}
494  				prxUintVref[0] = 2;
495  				status = prx.getReal(prxUintVref, 1, prxRealIo);
496  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
497  				{
498  						if( status == FMI_ERROR )
499  						{
500  								logger.log(4, "GetReal failed on '%s' with status: FMI_ERROR", prx);
501  						}
502  						if( status == FMI_FATAL )
503  						{
504  								logger.log(4, "GetReal failed on '%s' with status: FMI_FATAL", prx);
505  						}
506  						error "Failed to 'getReal' on 'prx'";
507  				}
508  				optUintVref[0] = 3;
509  				optUintVref[1] = 4;
510  				status = opt.getReal(optUintVref, 2, optRealIo);
511  				if( (status == FMI_ERROR) || (status == FMI_FATAL) )
512  				{
513  						if( status == FMI_ERROR )
514  						{
515  								logger.log(4, "GetReal failed on '%s' with status: FMI_ERROR", opt);
516  						}
517  						if( status == FMI_FATAL )
518  						{
519  								logger.log(4, "GetReal failed on '%s' with status: FMI_FATAL", opt);
520  						}
