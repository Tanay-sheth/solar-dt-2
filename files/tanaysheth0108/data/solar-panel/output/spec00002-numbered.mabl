341  			uint optUintVref[5];
342  			real jac_current_step_size = 0.0;
343  			real jac_step_size = 0.0;
344  			@TransferAs("START_TIME");
345  			real jac_current_communication_point = 0.0;
346  			real jac_end_time = 0.0;
347  			jac_current_step_size = STEP_SIZE;
348  			jac_step_size = STEP_SIZE;
