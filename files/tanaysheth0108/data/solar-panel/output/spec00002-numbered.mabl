350  			jac_end_time = END_TIME;
351  			string datawriter_headers[3] = { "{optimizer}.opt.out_target_pan" , "{optimizer}.opt.out_target_tilt" , "{proxy}.prx.out_current_power" };
352  			DataWriterConfig datawriter_configuration = dataWriter1.writeHeader(datawriter_headers);
353  			optUintVref[0] = 3;
