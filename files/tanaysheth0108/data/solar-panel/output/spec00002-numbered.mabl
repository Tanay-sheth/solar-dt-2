522  				}
523  				prxRealShare[0] = prxRealIo[0];
524  				optRealShare[0] = optRealIo[0];
525  				optRealShare[1] = optRealIo[1];
526  				if( !any_discards )
527  				{
528  						jac_current_communication_point = jac_current_communication_point + jac_current_step_size;
529  						dataWriter1.writeDataPoint(datawriter_configuration, jac_current_communication_point, optRealShare[0], optRealShare[1], prxRealShare[0]);
530  						jac_current_step_size = jac_step_size;
531  				}
532  			}
533  			dataWriter1.close();
534  		}		finally 
535  		{
536  			if( simulationControl != null )
537  			{
538  					unload(simulationControl);
539  					simulationControl = null;
540  			}
541  			if( dataWriter1 != null )
542  			{
543  					unload(dataWriter1);
544  					dataWriter1 = null;
545  			}
546  			if( booleanLogic2 != null )
547  			{
548  					unload(booleanLogic2);
549  					booleanLogic2 = null;
550  			}
551  		}
552  		opt.terminate();
553  		prx.terminate();
554  	}	finally 
555  	{
556  		if( (opt != null) )
557  		{
558  				optimizer.freeInstance(opt);
559  				opt = null;
560  		}
561  		if( (prx != null) )
562  		{
563  				proxy.freeInstance(prx);
564  				prx = null;
565  		}
566  		if( (optimizer != null) )
567  		{
568  				unload(optimizer);
569  				optimizer = null;
570  		}
571  		if( (proxy != null) )
572  		{
573  				unload(proxy);
574  				proxy = null;
575  		}
576  		if( (math != null) )
577  		{
578  				unload(math);
579  				math = null;
580  		}
581  		if( (logger != null) )
582  		{
583  				unload(logger);
584  				logger = null;
585  		}
586  		if( (dataWriter != null) )
587  		{
588  				unload(dataWriter);
589  				dataWriter = null;
590  		}
591  		if( (booleanLogic != null) )
592  		{
593  				unload(booleanLogic);
594  				booleanLogic = null;
595  		}
596  	}
597  }
